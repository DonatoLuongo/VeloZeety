{
  "expo": {
    "name": "VeloCity",
    "slug": "velocity",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/velocity-logo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/velocity-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.velocity.app" },
    "android": {
      "adaptiveIcon": { "foregroundImage": "./assets/velocity-logo.png", "backgroundColor": "#0F172A" },
      "package": "com.velocity.app"
    }
  }
}

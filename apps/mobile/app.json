{
  "expo": {
    "name": "VeloCity",
    "slug": "velocity",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/velocity-logo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/velocity-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.velocity.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "VeloCity necesita tu ubicación para mostrarte conductores cercanos y calcular rutas.",
        "NSLocationAlwaysUsageDescription": "VeloCity necesita tu ubicación en segundo plano para el seguimiento de viajes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/velocity-logo.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.velocity.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "FOREGROUND_SERVICE",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/velocity-logo.png",
          "color": "#F46E20"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f1f41124-6c78-4b45-baef-8ed6076a04dc"
      }
    }
  }
}

{
  "name": "velocity",
  "version": "0.1.0",
  "private": true,
  "description": "VeloCity - Tu ciudad en movimiento. Ride-sharing, wallet cripto, tienda y servicios.",
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "cd apps/web && npm run dev",
    "dev:api": "npm run start:dev --workspace=api",
    "dev:mobile": "npm run start --workspace=mobile",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build --workspace=web",
    "build:api": "npm run build --workspace=api",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "npm run db:migrate --workspace=api",
    "build:shared": "npm run build --workspace=@velocity/shared",
    "postinstall": "npm run build:shared"
  },
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0"
  }
}